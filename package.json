{
  "name": "cefr-vocab-reader",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:lexicon": "swift -module-cache-path .swift-module-cache scripts/generate_cefr_lexicon.swift",
    "start:backend": "wrangler dev --port 8787",
    "deploy:worker": "wrangler deploy",
    "configure:backend": "node scripts/set-extension-backend.mjs",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
